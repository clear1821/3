<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".MainActivity">

    <!-- 顶部连接控制区域 -->
    <LinearLayout
        android:id="@+id/layoutConnection"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:padding="5dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- IP输入框 -->
        <EditText
            android:id="@+id/etIp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:hint="IP地址"
            android:text="192.168.10.1"
            android:inputType="text"
            android:textSize="12sp"
            android:padding="5dp"
            android:background="@android:color/white"
            android:layout_marginEnd="5dp" />

        <!-- 端口输入框 -->
        <EditText
            android:id="@+id/etPort"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="端口"
            android:text="10000"
            android:inputType="number"
            android:textSize="12sp"
            android:padding="5dp"
            android:background="@android:color/white"
            android:layout_marginEnd="5dp" />

        <!-- 连接按钮 -->
        <Button
            android:id="@+id/btnConnect"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="连接"
            android:textSize="12sp"
            android:padding="0dp"
            android:layout_marginEnd="5dp" />

        <!-- 连接状态显示 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="未连接"
            android:textSize="12sp"
            android:gravity="center"
            android:background="@android:color/white"
            android:textColor="#FF0000" />

    </LinearLayout>
    <!--    显示宠物信息-->
    <LinearLayout
        android:orientation="horizontal"
        android:padding="5dp"
        android:layout_marginTop="5dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:gravity="center">
        <TextView
            android:layout_width="0dp"
            android:layout_weight="1"
            android:text="当前宠物："
            android:textSize="24sp"
            android:layout_height="match_parent"/>
        <TextView
            android:id="@+id/petName"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="当前无宠物"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#2196F3"
            android:gravity="center" />

    </LinearLayout>
    <!-- 食物信息显示区域 -->
    <LinearLayout
        android:id="@+id/layoutFoodInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="5dp"
        android:layout_marginTop="5dp"
        app:layout_constraintTop_toBottomOf="@id/layoutConnection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 食物剩余量 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="15dp"
            android:background="#F5F5F5">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="食物剩余量："
                android:textSize="18sp"
                android:textColor="#333333" />

            <TextView
                android:id="@+id/tvFoodRemaining"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0"
                android:textSize="24sp"
                android:textColor="#FF5722"
                android:textStyle="bold"
                android:gravity="center" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="克"
                android:textSize="18sp"
                android:textColor="#333333" />

        </LinearLayout>

    </LinearLayout>

    <!-- 控制开关区域 -->
    <LinearLayout
        android:id="@+id/layoutFeedControl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="1dp"
        app:layout_constraintTop_toBottomOf="@id/layoutFoodInfo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 手动投喂按钮 -->
        <ToggleButton
            android:id="@+id/btnManualFeed"
            android:layout_width="match_parent"
            android:layout_weight="1"
            android:layout_height="0dp"
            android:textOn="关闭手动投喂"
            android:textOff="开启手动投喂"
            android:textSize="18sp"
            android:backgroundTint="#2196F3"
            android:layout_marginBottom="1dp" />
            
        <!-- 灯开关 -->
        <ToggleButton
            android:id="@+id/btnLight"
            android:layout_weight="1"
            android:layout_height="0dp"
            android:textOn="关灯"
            android:textOff="开灯"
            android:textSize="18sp"
            android:layout_width="match_parent"
            android:backgroundTint="#546fe1" />

    </LinearLayout>
    
    <!-- 折线图区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="10dp">
        
        <!-- 图表标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="进食量统计图"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:gravity="center"
            android:layout_marginBottom="10dp" />
        
        <!-- 图表按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="10dp">

            <Button
                android:id="@+id/btnDaily"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="35dp"
                android:text="日"
                android:textSize="12sp"
                android:backgroundTint="#4CAF50"
                android:layout_marginEnd="5dp" />
                
            <Button
                android:id="@+id/btnWeekly"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="35dp"
                android:text="周"
                android:textSize="12sp"
                android:backgroundTint="#2196F3"
                android:layout_marginEnd="5dp" />
                
            <Button
                android:id="@+id/btnMonthly"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="35dp"
                android:text="月"
                android:textSize="12sp"
                android:backgroundTint="#FF9800"
                android:layout_marginEnd="5dp" />

            <Button
                android:id="@+id/btnRefreshChart"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="35dp"
                android:text="刷新"
                android:textSize="12sp"
                android:backgroundTint="#9C27B0"
                android:layout_marginEnd="5dp" />
        </LinearLayout>
        
        <!-- 折线图 -->
        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/lineChart"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F9F9F9" />

    </LinearLayout>
    
    <!-- 清除数据按钮 -->
    <Button
        android:id="@+id/btnClearData"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="清除保存的数据"
        android:textSize="16sp"
        android:backgroundTint="#F44336"
        android:layout_margin="10dp" />

</LinearLayout>